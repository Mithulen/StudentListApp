<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Update Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container w-50 text-center">
        <h2 class="mb-4">Update Student</h2>
        <form action="/editStudent/<%= student.studentid %>" method="POST" enctype="multipart/form-data">
            
            <div class="mb-3 text-start">
                <label class="form-label">Student Name:</label>
                <input type="text" class="form-control" name="studentName" value="<%= student.studentName %>" required>
            </div>
            <div class="mb-3 text-start">
                <label class="form-label">D.o.B:</label>
                <input type="text" class="form-control" name="dob" value="<%= student.dob %>" required>
            </div>
            <div class="mb-3 text-start">
                <label class="form-label">Contact:</label>
                <input type="text" class="form-control" name="contact" value="<%= student.contact %>" required>
            </div>

            <div class="mb-4 text-start">
                <label class="form-label">Current Image:</label><br>
                <input type="text" class="form-control mb-2" name="currentImage" value="<%= student.image %>" readonly>
                <div class="text-center">
                    <img src="/images/<%= student.image %>" width="120" class="mb-3 border rounded p-1">
                </div>
                <label class="form-label">New Image:</label>
                <input type="file" class="form-control" name="image" accept="image/*">
            </div>

            <button type="submit" class="btn btn-outline-dark px-4">Update Student</button>
            <br>
            <a href="/" class="text-decoration-none mt-3 d-inline-block">Back</a>
        </form>
    </div>
</body>
</html>