<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container w-50">
        <h2 class="text-center mb-4">Add New Student</h2>
        <form action="/addStudent" method="POST" enctype="multipart/form-data" class="text-center">
            <div class="mb-3 text-start">
                <label class="form-label">Student Name:</label>
                <input type="text" class="form-control" name="studentName" required>
            </div>
            <div class="mb-3 text-start">
                <label class="form-label">D.o.B:</label>
                <input type="text" class="form-control" name="dob" placeholder="MM/DD/YYYY" required>
            </div>
            <div class="mb-3 text-start">
                <label class="form-label">Contact:</label>
                <input type="text" class="form-control" name="contact" required>
            </div>
            <div class="mb-4 text-start">
                <label class="form-label">Image:</label>
                <input type="file" class="form-control" name="image" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-outline-dark px-4">Add Student</button>
        </form>
    </div>
</body>
</html>