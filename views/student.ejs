<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Student Details</title>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark mb-5">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">🎓 StudentList App</a>
      </div>
    </nav>

    <div class="container mt-5">
        <div class="text-center mb-4"><h2>Student Details</h2></div>
        
        <% if (student) { %> 
            <div class="card p-4 shadow mx-auto" style="max-width: 500px;">
                <div class="text-center mb-4">
                    <img src="<%= student.image %>" class="img-thumbnail rounded-circle shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Student Image">
                </div>
                <ul class="list-group list-group-flush">
                  <li class="list-group-item"><b>Student Name:</b> <%= student.name %></li>
                  <li class="list-group-item"><b>Date of Birth:</b> <%= new Date(student.dob).toLocaleDateString() %></li>
                  <li class="list-group-item"><b>Contact Number:</b> <%= student.contact %></li>
                </ul>
            </div>
        <% } else { %>
            <p class="alert alert-danger text-center">No student found.</p>
        <% } %>
        
        <div class="text-center mt-4">
            <a href="/" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</body>
</html>