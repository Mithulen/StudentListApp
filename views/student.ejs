<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Student Details</title>
</head>
<body>
    <div class="container mt-5">
        <div class="text-center"><h2>Student Details</h2></div>
        <br>
        
        <% if (student) { %> 
            <div class="card p-4 shadow-sm mx-auto" style="max-width: 500px;">
                <div class="text-center mb-3">
                    <img src="<%= student.image %>" class="img-thumbnail rounded" width="150" alt="Student Image">
                </div>
                <p><b>Student Name:</b> <%= student.name %></p>
                <p><b>Date of Birth:</b> <%= new Date(student.dob).toLocaleDateString() %></p>
                <p><b>Contact Number:</b> <%= student.contact %></p>
            </div>
        <% } else { %>
            <p class="alert alert-danger text-center">No student found.</p>
        <% } %>
        
        <div class="text-center mt-3">
            <a href="/" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</body>
</html>