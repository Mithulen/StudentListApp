<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>Student List App</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">🎓 StudentList App</a>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="/addStudent">Add New Student</a></li> 
          </ul>
        </div>
      </div>
    </nav>
    
  <div class="container mt-4">
    <div class="text-center mb-4"><h2>Students</h2></div>
    <table class="table table-hover align-middle text-center shadow-sm">
      <thead class="table-dark">
          <tr>
            <th>Name</th>
            <th>Image</th>
            <th>DOB</th>
            <th>Contact</th>
            <th>Edit</th>
            <th>Delete</th>
          </tr>
      </thead>
      <tbody>
        <% for(let i=0; i < students.length; i++) { %>
          <tr>
            <td><a href="/student/<%= students[i].studentid %>" class="text-decoration-none fw-bold"><%= students[i].name %></a></td>
            <td><img src="<%= students[i].image %>" width="60" height="60" class="rounded-circle" style="object-fit: cover;"></td>
            <td><%= new Date(students[i].dob).toLocaleDateString() %></td>
            <td><%= students[i].contact %></td>
            <td><a href="/editStudent/<%= students[i].studentid %>" class="btn btn-primary btn-sm">Edit</a></td>
            <td><a href="/deleteStudent/<%= students[i].studentid %>" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this student?')">Delete</a></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>