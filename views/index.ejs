<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student List App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="text-center mb-4">Students from Student List App Database</h2>
        <table class="table text-center align-middle">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Student Image</th>
                    <th>Dob</th>
                    <th>Contact</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i=0; i < students.length; i++) { %>
                <tr>
                    <td><%= students[i].studentName %></td>
                    <td><img src="/images/<%= students[i].image %>" width="60" alt="Student Image"></td>
                    <td><%= students[i].dob %></td>
                    <td><%= students[i].contact %></td>
                    <td><a href="/editStudent/<%= students[i].studentid %>">Edit</a></td>
                    <td><a href="/deleteStudent/<%= students[i].studentid %>" onclick="return confirm('Are you sure you want to delete this student(<%= students[i].studentName %>)?')">Delete</a></td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>